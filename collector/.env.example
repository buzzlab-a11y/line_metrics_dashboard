# collector ローカル実行用。実値は collector/.env にコピー（.env はコミットしない）
UTAGE_API_KEY=your_utage_api_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
# LINEレポート専用チャンネルのwebhook（推奨）。未設定なら下の汎用にフォールバック
DISCORD_WEBHOOK_URL_LINE=https://discord.com/api/webhooks/xxx/yyy
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
